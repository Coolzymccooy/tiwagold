{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "20.18.0",
      "channel": "base"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      },
      "env": {
        "USE_LIVE_BACKEND": "true",
        "PERSONA_OVERSEER_BASE_URL": "https://tiwa.tiwaton.co.uk"
      }
    },
    "production": {
      "extends": "base",
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "USE_LIVE_BACKEND": "true",
        "PERSONA_OVERSEER_BASE_URL": "https://tiwa.tiwaton.co.uk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
