{
  "expo": {
    "name": "Tiwa Gold",
    "slug": "tiwagold",
    "scheme": "tiwagold",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tiwagold.app",
      "infoPlist": {
        "UIRequiresFullScreen": true,
        "UIViewControllerBasedStatusBarAppearance": true
      }
    },
    "android": {
      "package": "com.tiwagold.app",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-splash-screen",
      "expo-font",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "USE_LIVE_BACKEND": false,
      "PERSONA_OVERSEER_BASE_URL": "",
      "PERSONA_OVERSEER_API_KEY": "",
      "PERSONA_OVERSEER_DEVICE_TOKEN": "",
      "eas": {
        "projectId": "63a5ce76-d497-4fc2-ab61-efd6349d314f"
      }
    },
    "owner": "coolzy"
  }
}
